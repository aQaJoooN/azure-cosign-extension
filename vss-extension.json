{
  "manifestVersion": 1,
  "id": "cosign-extension",
  "name": "Cosign Image Signing",
  "version": "1.0.1",
  "publisher": "aQaJoooN",
  "public": true,
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "description": "Sign container images with Cosign in air-gapped environments. Includes custom service connection for secure credential storage and Azure DevOps task for automated signing.",
  "categories": [
    "Azure Pipelines"
  ],
  "tags": [
    "cosign",
    "container",
    "docker",
    "security",
    "signing",
    "sigstore"
  ],
  "icons": {
    "default": "icon.png"
  },
  "content": {
    "details": {
      "path": "README.md"
    }
  },
  "links": {
    "home": {
      "uri": "https://github.com/aQaJoooN/azure-cosign-extension"
    },
    "support": {
      "uri": "https://github.com/aQaJoooN/azure-cosign-extension/issues"
    },
    "repository": {
      "uri": "https://github.com/aQaJoooN/azure-cosign-extension"
    },
    "issues": {
      "uri": "https://github.com/aQaJoooN/azure-cosign-extension/issues"
    }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/aQaJoooN/azure-cosign-extension"
  },
  "contributions": [
    {
      "id": "cosign-service-endpoint",
      "type": "ms.vss-endpoint.service-endpoint-type",
      "targets": [
        "ms.vss-endpoint.endpoint-types"
      ],
      "properties": {
        "name": "cosignServiceConnection",
        "displayName": "Cosign Signing Connection",
        "url": {
          "displayName": "Server URL",
          "helpText": "Registry URL (optional, leave empty if not needed)"
        },
        "authenticationSchemes": [
          {
            "type": "ms.vss-endpoint.endpoint-auth-scheme-none",
            "inputDescriptors": [
              {
                "id": "cosignPrivateKey",
                "name": "Cosign Private Key",
                "description": "The content of the Cosign private key file (cosign.key)",
                "inputMode": "textArea",
                "isConfidential": true,
                "validation": {
                  "isRequired": true,
                  "dataType": "string"
                }
              },
              {
                "id": "cosignPublicKey",
                "name": "Cosign Public Key",
                "description": "The content of the Cosign public key file (cosign.pub)",
                "inputMode": "textArea",
                "isConfidential": false,
                "validation": {
                  "isRequired": true,
                  "dataType": "string"
                }
              },
              {
                "id": "cosignPassword",
                "name": "Cosign Password",
                "description": "Password for the Cosign private key",
                "inputMode": "passwordBox",
                "isConfidential": true,
                "validation": {
                  "isRequired": true,
                  "dataType": "string"
                }
              }
            ]
          }
        ],
        "helpMarkDown": "Configure Cosign signing credentials for container image signing in air-gapped environments"
      }
    },
    {
      "id": "cosign-sign-task",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "tasks/CosignSign"
      }
    }
  ],
  "overview": "overview.md",
  "files": [
    {
      "path": "overview.md",
      "addressable": true
    },
    {
      "path": "tasks"
    },
    {
      "path": "README.md"
    }
  ]
}